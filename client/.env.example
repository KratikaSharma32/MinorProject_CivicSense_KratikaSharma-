# ─── API Configuration ────────────────────────────────────────────────────────
# Development (proxied via package.json "proxy" field):
# Leave blank and use the "proxy" field in package.json

# Production (set to your deployed API URL):
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# ─── Feature Flags ────────────────────────────────────────────────────────────
# REACT_APP_ENABLE_MAPS=true
# REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_key_here
