# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
client/build/
client/.next/
server/dist/

# ─── Environment files ────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env
# Keep .env.example in version control
!server/.env.example
!client/.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
server/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Uploads (user-generated content) ────────────────────────────────────────
server/uploads/*
!server/uploads/.gitkeep

# ─── Test coverage ────────────────────────────────────────────────────────────
coverage/
server/coverage/
.nyc_output/

# ─── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ─── IDEs ─────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*.sublime-workspace

# ─── Docker ───────────────────────────────────────────────────────────────────
.docker/

# ─── SSL certs (never commit) ─────────────────────────────────────────────────
nginx/ssl/
*.pem
*.key
*.crt
*.p12

# ─── Misc ─────────────────────────────────────────────────────────────────────
.eslintcache
*.tgz
.cache/
